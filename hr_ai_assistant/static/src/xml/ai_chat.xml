<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="hr_ai_assistant.AIChat">

        <div class="ai-chat-container">

            <button
                class="ai-chat-button"
                t-on-click="toggleChat"
            >
                🤖
            </button>

            <div
                t-if="state.open"
                class="ai-chat-popup"
            >

                <div class="ai-chat-header">
                    HR AI Assistant
                </div>

                <div class="ai-chat-messages">

                    <t
                        t-foreach="state.messages"
                        t-as="msg"
                        t-key="msg.id"
                    >

                        <div
                            t-att-class="'message ' + msg.sender"
                        >
                            <t t-esc="msg.text"/>
                        </div>

                    </t>

                </div>

                <div
                    class="ai-chat-input-area"
                >

                    <input
                        type="text"
                        class="ai-chat-input"
                        placeholder="Ask HR..."
                        t-model="state.message"
                        t-on-keydown="onKeyDown"
                    />

                    <button
                        class="send-btn"
                        t-on-click="sendMessage"
                        t-att-disabled="state.loading"
                    >

                        <t t-if="state.loading">
                            Sending...
                        </t>

                        <t t-else="">
                            Send
                        </t>

                    </button>

                </div>

            </div>

        </div>

    </t>

</templates>